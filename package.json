{
  "name": "n8n-nodes-apivault-tiktok-profile",
  "version": "0.1.0",
  "description": "n8n community node for TikTok Profile Scraper — get real-time TikTok profile data (followers, likes, videos, bio, verification) plus creator-tier and engagement-rate signals. No TikTok API key. Pay-as-you-go, no monthly fee.",
  "license": "MIT",
  "homepage": "https://apify.com/apivault_labs/tiktok-profile-scraper",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "tiktok",
    "tiktok-scraper",
    "tiktok-profile",
    "tiktok-followers",
    "tiktok-stats",
    "influencer-marketing",
    "influencer-discovery",
    "creator-economy",
    "engagement-rate",
    "social-media-scraper",
    "apify"
  ],
  "author": {
    "name": "apivault_labs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/apivault-labs/n8n-nodes-apivault-tiktok-profile.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && copyfiles \"nodes/**/*.svg\" dist",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ApifyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/TikTokProfile/TikTokProfile.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "copyfiles": "^2.4.1",
    "n8n-workflow": "*",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
